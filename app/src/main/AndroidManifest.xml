<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- AI Apps 包名白名单 (用于检测是否安装及跨应用协同) -->
    <queries>
        <!-- ChatGPT -->
        <package android:name="com.openai.chatgpt" />
        <!-- Claude -->
        <package android:name="com.anthropic.claude" />
        <!-- Gemini -->
        <package android:name="com.google.android.apps.bard" />
        <!-- 豆包 (Doubao) -->
        <package android:name="com.bytedance.mira.macaron" />
        <!-- DeepSeek -->
        <package android:name="com.deepseek.chat" />
        <!-- Kimi -->
        <package android:name="com.moonshot.kimi" />
        <!-- 通义千问 (Tongyi) -->
        <package android:name="com.alibaba.tongyi" />
        <!-- 智谱清言 (Zhipu) -->
        <package android:name="cn.zhipu.chatglm" />
    </queries>

    <application
        android:name=".VoiceBridgeApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 注册前台整理保活服务 -->
        <service 
            android:name=".service.TranscriptionForegroundService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!-- 注册对标 ShareExtension 的音频接收 Activity -->
        <activity
            android:name=".ui.ShareImportActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>
        </activity>

    </application>

</manifest>
